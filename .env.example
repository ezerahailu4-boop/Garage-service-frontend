# Birhan Garage Management Platform — Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3000
DOMAIN=localhost

# API (replace with real backend URL when ready)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Auth
VITE_JWT_SECRET=change-me-in-production

# App
VITE_APP_NAME="Birhan Garage"
VITE_APP_VERSION=2.0.0
